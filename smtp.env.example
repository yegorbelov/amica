# Copy into your project `.env` (do not commit real passwords).
# Gmail: Account → Security → 2-Step Verification → App passwords.
#
# Port 587 (recommended): TLS after connect (defaults below).
# Port 465: set EMAIL_PORT=465, EMAIL_USE_TLS=False, EMAIL_USE_SSL=True

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=you@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-16-chars
DEFAULT_FROM_EMAIL=you@gmail.com
